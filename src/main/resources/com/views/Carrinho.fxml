<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.controller.CarrinhoController"
            prefWidth="420" prefHeight="560">

    <top>
        <HBox alignment="CENTER_LEFT" styleClass="carrinho-header">
            <padding>
                <Insets top="16" right="16" bottom="16" left="16"/>
            </padding>
            <Label text="Seu Carrinho" styleClass="titulo-tela"/>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" styleClass="scroll-carrinho">
            <VBox fx:id="containerItens" spacing="8">
                <padding>
                    <Insets top="10" right="14" bottom="10" left="14"/>
                </padding>
                <!-- CarrinhoItem.fxml são injetados aqui em runtime -->
            </VBox>
        </ScrollPane>
    </center>

    <bottom>
        <VBox spacing="8" styleClass="carrinho-footer">
            <padding>
                <Insets top="12" right="16" bottom="12" left="16"/>
            </padding>

            <HBox alignment="CENTER_LEFT">
                <Label text="Valor total: " styleClass="label-rodape"/>
                <Label fx:id="lblValorTotal" text="R$ 0,00" styleClass="valor-total"/>
            </HBox>

            <HBox alignment="CENTER_LEFT">
                <Label text="Tempo de entrega: " styleClass="label-rodape"/>
                <Label text="45 minutos" styleClass="tempo-entrega"/>
            </HBox>

            <Button fx:id="btnFinalizar" text="Finalizar Pedido" onAction="#onFinalizarPedido" maxWidth="Infinity"/>
        </VBox>
    </bottom>

</BorderPane>
