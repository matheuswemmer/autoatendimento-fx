<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.controller.CozinhaController"
            prefWidth="900" prefHeight="650">

    <top>
        <HBox alignment="CENTER_LEFT" styleClass="cozinha-header">
            <padding>
                <Insets top="16" right="16" bottom="16" left="16"/>
            </padding>
            <Label text="Painel da Cozinha" styleClass="titulo-tela"/>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" styleClass="scroll-cozinha">
            <VBox fx:id="containerPedidos" spacing="12">
                <padding>
                    <Insets top="12" right="12" bottom="12" left="12"/>
                </padding>
            </VBox>
        </ScrollPane>
    </center>

    <bottom>
        <HBox alignment="CENTER_RIGHT" spacing="10" styleClass="cozinha-footer">
            <padding>
                <Insets top="12" right="16" bottom="12" left="16"/>
            </padding>
            <Button fx:id="btnNovoPedido" text="Novo Pedido" onAction="#onNovoPedido"/>
        </HBox>
    </bottom>

</BorderPane>
