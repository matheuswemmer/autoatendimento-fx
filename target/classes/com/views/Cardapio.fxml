<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.controller.CardapioController"
            prefWidth="480" prefHeight="640">

    <!-- Cabeçalho fixo -->
    <top>
        <HBox alignment="CENTER_LEFT" styleClass="cardapio-header">
            <padding>
                <Insets top="16" right="16" bottom="16" left="16"/>
            </padding>
            <Label text="Cardápio" styleClass="titulo-tela"/>
        </HBox>
    </top>

    <!-- Lista de produtos, rolável -->
    <center>
        <ScrollPane fitToWidth="true" styleClass="scroll-cardapio">
            <VBox fx:id="containerProdutos" spacing="10">
                <padding>
                    <Insets top="10" right="14" bottom="10" left="14"/>
                </padding>
                <!-- Os ProdutoCard.fxml são injetados aqui em runtime pelo CardapioController -->
            </VBox>
        </ScrollPane>
    </center>


    <!-- Rodapé fixo com acesso ao carrinho -->
    <bottom>
        <HBox alignment="CENTER_RIGHT" spacing="10" styleClass="cardapio-footer">
            <padding>
                <Insets top="12" right="16" bottom="12" left="16"/>
            </padding>
            <Button fx:id="btnVerCarrinho" text="Ver Carrinho" onAction="#onVerCarrinho"/>
        </HBox>
    </bottom>

</BorderPane>
