<VBox alignment="CENTER" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="424.0" prefWidth="320.0" spacing="20.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.CozinhaController">
   <children>
      <Label text="Seja bem vindo a cozinha!" />
      <Button fx:id="newProduct" mnemonicParsing="false" onAction="#registerNewProduct" text="Cadastrar novo produto" />
      <Button fx:id="menuProducts" onAction="#seeMenuProducts" text="Ver o cardápio" />
      <Button fx:id="getBackButton" onAction="#swithToPrimary" text="Voltar" />
   </children>
   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
   </padding>
</VBox>
